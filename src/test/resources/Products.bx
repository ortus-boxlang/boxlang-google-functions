class {

	function run( event, context, response ) {
		var httpMethod = "GET";
		if ( structKeyExists( event, "requestContext" ) && structKeyExists( event.requestContext, "http" ) ) {
			httpMethod = event.requestContext.http.method;
		} else if ( structKeyExists( event, "method" ) ) {
			httpMethod = event.method;
		}

		// RequestMapper does not populate pathParameters, so derive the optional
		// numeric ID from the second segment of event.path (e.g. /products/123).
		var pathId = "";
		var pathParts = listToArray( event.path ?: "/", "/" );
		if ( arrayLen( pathParts ) >= 2 && isNumeric( pathParts[ 2 ] ) ) {
			pathId = pathParts[ 2 ];
		}

		switch ( httpMethod ) {
			case "GET":
				if ( len( pathId ) > 0 ) {
					return getProduct( pathId );
				} else {
					return getAllProducts();
				}
				break;

			case "POST":
				return createProduct( event.body );
				break;

			default:
				response.statusCode = 405;
				return { "error": "Method not allowed" };
		}
	}

	function getAllProducts() {
		return {
			"message": "Test: Fetching all products",
			"data": [
				{ "id": 1, "name": "Test Product 1", "price": 29.99 },
				{ "id": 2, "name": "Test Product 2", "price": 39.99 }
			],
			"total": 2
		};
	}

	function getProduct( id ) {
		return {
			"message": "Test: Fetching product ##" & id,
			"data": {
				"id": id,
				"name": "Test Product " & id,
				"price": 29.99
			}
		};
	}

	function createProduct( body ) {
		return {
			"message": "Test: Product created successfully",
			"data": {
				"id": 999,
				"name": "New Test Product",
				"created": true
			}
		};
	}
}
