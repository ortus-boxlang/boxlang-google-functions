/**
 * Test Lambda.bx — default handler used by GCPFunctionRunnerTest
 */
class {

	function run( event, context, response ) {
		println( "====> [Test] Lambda.run() called" );
		println( event );
		println( response );
	}

	function hello( event, context, response ) {
		println( "====> [Test] Lambda.hello() called" );
		return "Hello Baby";
	}
}
